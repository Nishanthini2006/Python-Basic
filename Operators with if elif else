a = int(input("Enter a: "))
b = int(input("Enter b: "))
print("Add:", a + b)
print("Minus:", a - b)
print("Multiply:", a * b)
print("Divide:", a / b)
print("Modulus:", a % b)
if a > b and a % 2 == 0:
    print("A is greater and even")
elif a < b or b % 2 == 0:
    print("B is greater or even")
else:
    print("Both are odd and A >= B")
